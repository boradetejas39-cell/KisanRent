<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FarmRent – Subscription Plans</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar">
        <div class="navbar-inner">
            <a href="home.html" class="navbar-brand">
                <span class="brand-icon">🚜</span> FarmRent
            </a>
            <div class="navbar-links">
                <a href="home.html" class="nav-link"><span class="nav-icon">🏠</span> Home</a>
                <a href="explore.html" class="nav-link"><span class="nav-icon">🔍</span> Explore</a>
                <a href="list-item.html" class="nav-link"><span class="nav-icon">＋</span> List</a>
                <a href="my-rentals.html" class="nav-link"><span class="nav-icon">📋</span> Rentals</a>
            </div>
            <div class="navbar-right">
                <a href="profile.html" class="nav-avatar">RP</a>
            </div>
        </div>
    </nav>

    <!-- Page Header -->
    <div class="page-header">
        <div class="page-header-inner">
            <h1>Subscription Plans</h1>
            <p>Choose the plan that fits your farming needs</p>
        </div>
    </div>

    <!-- Plans Content -->
    <div class="page-wrapper" style="background: var(--gray-100);">
        <div class="container">

            <!-- Plans Grid -->
            <div class="plans-grid">

                <!-- Free Plan -->
                <div class="plan-card">
                    <div class="plan-header">
                        <span class="plan-icon">🌱</span>
                        <h3 class="plan-name">Free</h3>
                        <div class="plan-price">₹0 <span class="plan-period">/month</span></div>
                        <p class="plan-tagline">Get started with basics</p>
                    </div>
                    <ul class="plan-features">
                        <li><span class="check">✓</span> Browse all equipment</li>
                        <li><span class="check">✓</span> Up to 2 bookings/month</li>
                        <li><span class="check">✓</span> 1 equipment listing</li>
                        <li><span class="check">✓</span> Basic support</li>
                        <li class="disabled"><span class="cross">✕</span> Priority listing</li>
                        <li class="disabled"><span class="cross">✕</span> Discount on rentals</li>
                        <li class="disabled"><span class="cross">✕</span> Analytics dashboard</li>
                    </ul>
                    <div class="plan-footer">
                        <a href="#" class="btn btn-outline" style="width:100%;">Current Plan</a>
                    </div>
                </div>

                <!-- Pro Plan -->
                <div class="plan-card featured">
                    <div class="plan-badge">Most Popular</div>
                    <div class="plan-header">
                        <span class="plan-icon">⭐</span>
                        <h3 class="plan-name">Pro</h3>
                        <div class="plan-price">₹499 <span class="plan-period">/month</span></div>
                        <p class="plan-tagline">For regular farmers &amp; renters</p>
                    </div>
                    <ul class="plan-features">
                        <li><span class="check">✓</span> Unlimited bookings</li>
                        <li><span class="check">✓</span> Up to 10 equipment listings</li>
                        <li><span class="check">✓</span> Priority listing placement</li>
                        <li><span class="check">✓</span> 5% discount on all rentals</li>
                        <li><span class="check">✓</span> Basic analytics dashboard</li>
                        <li><span class="check">✓</span> Priority support</li>
                        <li class="disabled"><span class="cross">✕</span> Free insurance</li>
                    </ul>
                    <div class="plan-footer">
                        <a href="#" class="btn btn-primary" style="width:100%;">Upgrade to Pro</a>
                    </div>
                </div>

                <!-- Business Plan -->
                <div class="plan-card">
                    <div class="plan-header">
                        <span class="plan-icon">🚀</span>
                        <h3 class="plan-name">Business</h3>
                        <div class="plan-price">₹1,499 <span class="plan-period">/month</span></div>
                        <p class="plan-tagline">For equipment dealers &amp; agencies</p>
                    </div>
                    <ul class="plan-features">
                        <li><span class="check">✓</span> Everything in Pro</li>
                        <li><span class="check">✓</span> Unlimited equipment listings</li>
                        <li><span class="check">✓</span> Featured listings (top of search)</li>
                        <li><span class="check">✓</span> 15% discount on all rentals</li>
                        <li><span class="check">✓</span> Advanced analytics dashboard</li>
                        <li><span class="check">✓</span> Free insurance on all bookings</li>
                        <li><span class="check">✓</span> Dedicated account manager</li>
                    </ul>
                    <div class="plan-footer">
                        <a href="#" class="btn btn-outline" style="width:100%;">Upgrade to Business</a>
                    </div>
                </div>

            </div>

            <!-- Annual Discount Banner -->
            <div class="annual-banner">
                <div class="banner-content">
                    <span style="font-size:28px;">🎉</span>
                    <div>
                        <h3>Save 20% with Annual Billing</h3>
                        <p>Switch to yearly plans and save up to ₹3,600 per year on Pro and Business plans.</p>
                    </div>
                    <a href="#" class="btn btn-primary btn-sm btn-auto">Switch to Annual</a>
                </div>
            </div>

            <!-- FAQ -->
            <div class="faq-section">
                <h2 style="text-align:center; margin-bottom:28px;">Frequently Asked Questions</h2>
                <div class="faq-list">
                    <div class="faq-item">
                        <div class="faq-q">Can I cancel my subscription anytime?</div>
                        <div class="faq-a">Yes, you can cancel your subscription anytime from your profile settings.
                            Your benefits will continue until the end of the current billing period.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-q">How does the rental discount work?</div>
                        <div class="faq-a">Pro members get 5% off and Business members get 15% off on the base rental
                            price of any equipment. The discount is automatically applied at checkout.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-q">Can I upgrade my plan mid-cycle?</div>
                        <div class="faq-a">Absolutely! When you upgrade, you'll be charged a prorated amount for the
                            remainder of your billing cycle. New benefits activate immediately.</div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-grid">
                <div>
                    <div class="footer-brand"><span>🚜</span> FarmRent</div>
                    <p class="footer-desc">India's largest farming equipment rental platform.</p>
                </div>
                <div class="footer-col">
                    <h4>Quick Links</h4>
                    <a href="home.html" class="footer-link">Home</a>
                    <a href="explore.html" class="footer-link">Explore</a>
                    <a href="list-item.html" class="footer-link">List Equipment</a>
                </div>
                <div class="footer-col">
                    <h4>Categories</h4>
                    <a href="explore.html" class="footer-link">Vehicles</a>
                    <a href="explore.html" class="footer-link">Machinery</a>
                    <a href="explore.html" class="footer-link">Tools</a>
                </div>
                <div class="footer-col">
                    <h4>Support</h4>
                    <a href="#" class="footer-link">Help Center</a>
                    <a href="#" class="footer-link">Terms &amp; Conditions</a>
                    <a href="#" class="footer-link">Privacy Policy</a>
                </div>
            </div>
            <div class="footer-bottom">&copy; 2026 FarmRent. All rights reserved.</div>
        </div>
    </footer>

</body>

</html>